APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Makassar
APP_SECRET=change-this-to-a-long-random-secret
APP_SESSION_NAME=EDOKTERSESSID
APP_SESSION_SAMESITE=Lax
APP_SESSION_DOMAIN=
APP_SESSION_SECURE=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=edokter
DB_USERNAME=edokter_user
DB_PASSWORD=change-this-db-password

# Keep this false in production.
APP_ALLOW_BYPASS_LOGIN=false
APP_BYPASS_USERNAME=
APP_BYPASS_PASSWORD=

# Optional logo file under public/setting/logo/
APP_LOGO_FILE=logo.png
